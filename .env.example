# Configuración de Sinego
# Copia este archivo a .env y ajusta los valores según tu entorno

# Base de datos
DB_HOST=localhost
DB_USER=sinego_user
DB_PASS=sinego_password
DB_NAME=sinego

# Sesión (en producción, cambiar a true y forzar HTTPS)
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# Aplicación
APP_DEBUG=false
APP_TIMEZONE=America/Caracas
APP_LOG_DIR=logs
